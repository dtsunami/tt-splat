# tt-splat (ttgs) environment configuration
# Copy this file to .env and edit for your machine:  cp .env.example .env
# ttgs loads .env automatically on every run (walks up from the CWD) — no shell setup needed.
# Verify what got picked up with:  ttgs info

# ── Tenstorrent / tt-metal ──────────────────────────────────────────────────────
# Point these at your built tt-metal tree (the one whose python_env has torch + ttnn).
# Required for the device path (ttgs blackhole). Recover a wedged card with: tt-smi -r 0
TT_METAL_HOME=/home/starboy/tt-metal
TT_METAL_RUNTIME_ROOT=/home/starboy/tt-metal

# ── Host-reference render budget (ttgs blackhole) ───────────────────────────────
# The host-reference training loop renders at TT_SIZE px from up to TT_MAX_POINTS
# Gaussians. Raise for fidelity, lower for speed. (Defaults: 1200 / 96.)
TT_MAX_POINTS=1200
TT_SIZE=96

# ── External tools (data prep) ──────────────────────────────────────────────────
# Each accepts either a directory containing the binary, or the full path to it.
# Leave unset to fall back to a normal PATH lookup.

# ffmpeg + ffprobe — frame extraction from video (only needed for `ttgs extract` / video input)
#   Linux: sudo apt install ffmpeg
#FFMPEG_PATH=
#FFPROBE_PATH=

# COLMAP — structure from motion (camera poses + sparse point cloud for `ttgs sfm`)
#   Linux: sudo apt install colmap
#COLMAP_PATH=
