# Python
**/__pycache__/
*.pyc
*.egg-info/
.venv/

# Local env config (holds machine-specific paths) — keep .env.example tracked
.env

# Build / generated artifacts
**/build
**/generated

# work/: keep the input dataset (scene model + source frames), ignore training outputs.
# NOTE: keep these as own-line comments — gitignore does NOT support inline comments.
work/*
!work/scene
!work/frames
